{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/webgl-vk/index.html"
    }
  ],
  "headers": [
    {
      "source": "/webgl-vk/(.*\\.(wasm|unityweb|data|js))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}