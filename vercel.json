{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/webgl-vk/index.html"
    }
  ],
  "headers": [
    {
      "source": "/webgl-vk/Build/(.*)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/javascript"
        }
      ]
    },
    {
      "source": "/webgl-vk/(.*\\.(wasm|unityweb|data))",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/octet-stream"
        }
      ]
    }
  ]
}